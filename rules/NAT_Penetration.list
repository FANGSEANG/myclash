# NAT Penetration内网穿透相关

#-------------------------
# Tailscale相关
#-------------------------

# 进程
PROCESS-NAME,tailscaled

# DERP Servers中继服务器
DOMAIN-REGEX,^derp\d*-?.*\.tailscale\.com$
DOMAIN-REGEX,^derp.*tailscale\.com

# 其他域名
DOMAIN-SUFFIX,tailscale.io
DOMAIN-SUFFIX,ts.net
DOMAIN-SUFFIX,tailscale.com

# IP绕过
IP-CIDR,100.64.0.0/10,no-resolve
IP-CIDR,fd7a:115c:a1e0::/48,no-resolve

# 常用端口
DST-PORT,41641
SRC-PORT,41641

# peer relays端口
DST-PORT,40000
SRC-PORT,40000

